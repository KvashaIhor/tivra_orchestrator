# Insforge — redeem credit at insforge.dev/promo/BELLE26, then get all values from your project dashboard

# Admin access token — used by @insforge/cli for non-interactive provisioning (CREATE TABLE, storage buckets)
INSFORGE_ACCESS_TOKEN=your_insforge_access_token_here

# Project ID — used by @insforge/cli when INSFORGE_ACCESS_TOKEN is set
INSFORGE_PROJECT_ID=your_insforge_project_id_here

# Project base URL — copy from your Insforge dashboard (e.g. https://my-app.us-east.insforge.app)
INSFORGE_BASE_URL=https://your-project.region.insforge.app

# Anon key — copy from your Insforge dashboard; injected into generated apps as NEXT_PUBLIC_INSFORGE_ANON_KEY
INSFORGE_ANON_KEY=your_insforge_anon_key_here

# OpenAI — used for spec parsing (gpt-4o) AND code generation (gpt-4o)
OPENAI_API_KEY=your_openai_api_key_here

# Vercel — generate at vercel.com/account/tokens
VERCEL_TOKEN=your_vercel_token_here

CORS_ORIGIN=http://localhost:3000
PORT=3001

# Debug: logs the enriched code-generation prompt (with sensitive env values redacted)
STRICT_PROMPT_DEBUG=false
